\begin{tikzpicture}[
  font=\small,
  >=Latex,
  core/.style={draw=black!75, rounded corners=2.5mm, thick, align=center, minimum height=12mm, fill=white},
  modA/.style={draw=blue!70!black, rounded corners=2.5mm, thick, align=center, text width=31mm, minimum height=11mm, fill=blue!8},
  modB/.style={draw=orange!75!black, rounded corners=2.5mm, thick, align=center, text width=31mm, minimum height=11mm, fill=orange!10},
  modC/.style={draw=green!55!black, rounded corners=2.5mm, thick, align=center, text width=31mm, minimum height=11mm, fill=green!10},
  modD/.style={draw=purple!70!black, rounded corners=2.5mm, thick, align=center, text width=31mm, minimum height=11mm, fill=purple!8},
  mainflow/.style={-Latex, very thick, draw=black!80},
  modflow/.style={-Latex, thick, draw=black!65},
  feedback/.style={-Latex, thick, dashed, draw=black!55}
]

\node[core, text width=34mm] (env) at (0,0) {Environment};
\node[core, text width=43mm, minimum height=16mm] (agent) at (6.2,0) {RL Agent\\{\footnotesize Policy, Value, Replay}};

\node[modA] (planner) at (11.2, 2.9) {Planner\\Decomposer};
\node[modB] (reward)  at (15.2, 2.9) {Reward\\Verifier};
\node[modC] (world)   at (11.2,-2.9) {World Model\\Simulator};
\node[modD] (tool)    at (15.2,-2.9) {Tool + Memory\\Interface};

\draw[mainflow] (env.east) -- node[above] {$s_t$} (agent.west);
\draw[mainflow] (agent.west) -- ++(-1.8,0) |- node[left, pos=0.30] {$a_t$} (env.south);
\draw[mainflow] (env.north) to[out=25, in=155] node[above] {$r_t,\ s_{t+1}$} (agent.north);

\coordinate (agentTop) at ($(agent.east)+(0,0.95)$);
\coordinate (agentTopR) at ($(agent.east)+(0,0.35)$);
\coordinate (agentBot) at ($(agent.east)+(0,-0.95)$);
\coordinate (agentBotR) at ($(agent.east)+(0,-0.35)$);

\draw[modflow] (planner.west) -- ++(-1.0,0) |- (agentTop);
\draw[modflow] (reward.west)  -- ++(-1.0,0) |- (agentTopR);
\draw[modflow] (world.west)   -- ++(-1.0,0) |- (agentBot);
\draw[modflow] (tool.west)    -- ++(-1.0,0) |- (agentBotR);

\draw[feedback] (agent.east) -- ++(0.8,0) |- (planner.south);
\draw[feedback] (agent.east) -- ++(1.2,0) |- (reward.south);
\draw[feedback] (agent.east) -- ++(0.8,0) |- (world.north);
\draw[feedback] (agent.east) -- ++(1.2,0) |- (tool.north);

\node[draw=black!35, rounded corners=1.6mm, fill=gray!8, align=left, inner sep=2.5mm, anchor=north west, text width=108mm] at (-1.1,-4.3)
{\footnotesize Module outputs intervene through subgoal priors, shaped supervision, imagined rollouts, and tool-memory context that modify trajectory-level updates.};

\end{tikzpicture}
